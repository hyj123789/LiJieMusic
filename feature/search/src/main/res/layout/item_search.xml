<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/ivSearchCover"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="#EEEEEE"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:src="@drawable/media3_icon_plus" />

    <TextView
        android:id="@+id/tvSearchSongName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#333333"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/tvSearchSinger"
        app:layout_constraintEnd_toStartOf="@+id/ivSearchMore"
        app:layout_constraintStart_toEndOf="@+id/ivSearchCover"
        app:layout_constraintTop_toTopOf="@+id/ivSearchCover"
        android:text="海阔天空" />

    <TextView
        android:id="@+id/tvSearchSinger"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#888888"
        android:textSize="13sp"
        app:layout_constraintBottom_toBottomOf="@+id/ivSearchCover"
        app:layout_constraintEnd_toStartOf="@+id/ivSearchMore"
        app:layout_constraintStart_toEndOf="@+id/ivSearchCover"
        app:layout_constraintTop_toBottomOf="@+id/tvSearchSongName"
        android:text="Beyond" />

    <ImageView
        android:id="@+id/ivSearchMore"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:padding="5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#BDBDBD"
        android:src="@drawable/ic_paly" />

</androidx.constraintlayout.widget.ConstraintLayout>