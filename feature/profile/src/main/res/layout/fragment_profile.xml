<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F8"
    tools:context=".ProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ========== 头部资料区域 ========== -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_avatar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_header"
            android:paddingBottom="24dp">
            <!-- 头像 -->
            <ImageView
                android:id="@+id/iv_avatar"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_marginTop="48dp"
                android:background="@drawable/bg_avatar_circle"
                android:clipToOutline="true"
                android:elevation="4dp"
                android:scaleType="centerCrop"
                android:src="@drawable/iv_avatar"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- 昵称 -->
            <TextView
                android:id="@+id/tv_nickname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="用户名"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_avatar" />

            <!-- VIP 标签 -->
            <TextView
                android:id="@+id/tv_vip"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_vip_tag"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="非会员"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_nickname" />

            <!-- 个性签名 -->
            <TextView
                android:id="@+id/tv_signature"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:paddingHorizontal="32dp"
                android:text="追求卓越，成功就会在不经意间找上你~~~"
                android:textColor="#DDFFFFFF"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_vip" />

            <!-- 关注/粉丝统计 -->
            <LinearLayout
                android:id="@+id/ll_follow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tv_signature">

                <TextView
                    android:id="@+id/tv_follows"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="32dp"
                    android:text="0 关注"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="16dp"
                    android:background="#66FFFFFF" />

                <TextView
                    android:id="@+id/tv_followeds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="32dp"
                    android:text="0 粉丝"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ========== 快捷功能入口 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-20dp"
            android:background="@drawable/bg_card_rounded"
            android:elevation="3dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_music_note"
                android:drawablePadding="4dp"
                android:gravity="center"
                android:text="本地音乐"
                android:textColor="#333333"
                android:textSize="12sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#EEEEEE" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_download"
                android:drawablePadding="4dp"
                android:gravity="center"
                android:text="下载管理"
                android:textColor="#333333"
                android:textSize="12sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#EEEEEE" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_recent"
                android:drawablePadding="4dp"
                android:gravity="center"
                android:text="最近播放"
                android:textColor="#333333"
                android:textSize="12sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="32dp"
                android:background="#EEEEEE" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_cloud"
                android:drawablePadding="4dp"
                android:gravity="center"
                android:text="云盘"
                android:textColor="#333333"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- ========== 我的歌单标题 ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="我的歌单"
                android:textColor="#333333"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_playlist_count"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_count_badge"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="11sp" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_check_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="查看全部 ›"
                android:textColor="#999999"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 歌单列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_playlist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="12dp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
