<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragment.LoginFragment">
<androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >
    <TextView
        android:id="@+id/tv_guest_login"
        android:padding="15dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="游客登录请点这里哇"
        android:layout_margin="5dp"/>
    <!-- ========== 顶部品牌标识 ========== -->
    <TextView
        android:id="@+id/tv_app_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="120dp"
        android:text="LiJie Music"
        android:textColor="@color/accent_green"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ========== 手机号输入框 ========== -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_phone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="56dp"
        android:hint="请输入手机号"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_app_title"
        app:startIconDrawable="@drawable/ic_phone">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="phone"
            android:maxLines="1"
            android:textSize="16sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- ========== 验证码输入框 + 获取按钮（水平排列） ========== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_captcha"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/til_phone">

        <!-- 验证码输入框 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_captcha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="请输入验证码"
            app:layout_constraintEnd_toStartOf="@id/btn_captcha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:startIconDrawable="@drawable/ic_captcha">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLines="1"
                android:textSize="16sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 获取验证码按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_captcha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:minWidth="96dp"
            android:text="获取验证码"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/til_captcha"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/til_captcha"
            app:layout_constraintTop_toTopOf="@id/til_captcha" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ========== 登录按钮 ========== -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_login"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="40dp"
        android:text="登  录"
        android:textSize="16sp"
        app:backgroundTint="@color/accent_green"
        app:cornerRadius="26dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cl_captcha" />

    <!-- ========== 其他登录方式（带横线分隔） ========== -->
    <View
        android:id="@+id/v_divider_left"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="12dp"
        android:background="@color/text_tertiary"
        app:layout_constraintBottom_toBottomOf="@id/tv_divider_label"
        app:layout_constraintEnd_toStartOf="@id/tv_divider_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_divider_label" />

    <TextView
        android:id="@+id/tv_divider_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="56dp"
        android:text="其他登录方式"
        android:textColor="@color/text_tertiary"
        android:textSize="14sp"
        app:layout_constraintEnd_toStartOf="@id/v_divider_right"
        app:layout_constraintStart_toEndOf="@id/v_divider_left"
        app:layout_constraintTop_toBottomOf="@id/btn_login" />

    <View
        android:id="@+id/v_divider_right"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="32dp"
        android:background="@color/text_tertiary"
        app:layout_constraintBottom_toBottomOf="@id/tv_divider_label"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/tv_divider_label"
        app:layout_constraintTop_toTopOf="@id/tv_divider_label" />

    <!-- ========== 其他登录图标 ========== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_mail"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:cardCornerRadius="28dp"
        app:cardElevation="2dp"
        app:layout_constraintEnd_toStartOf="@id/cv_scan"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_divider_label">

        <ImageView
            android:id="@+id/btn_login_mail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="14dp"
            android:src="@drawable/ic_mail"
            android:contentDescription="邮箱登录" />

    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_scan"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:cardCornerRadius="28dp"
        app:cardElevation="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/cv_mail"
        app:layout_constraintTop_toBottomOf="@id/tv_divider_label">

        <ImageView
            android:id="@+id/btn_login_scan"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="14dp"
            android:src="@drawable/ic_scan"
            android:contentDescription="扫码登录" />

    </androidx.cardview.widget.CardView>

    <!-- ========== 底部注册链接 ========== -->
    <TextView
        android:id="@+id/tv_register"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:clickable="true"
        android:focusable="true"
        android:text="还没有账号？请点击这里"
        android:textColor="@color/accent_green"
        android:textSize="15sp"
        app:layout_constraintTop_toBottomOf="@id/cv_mail"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>