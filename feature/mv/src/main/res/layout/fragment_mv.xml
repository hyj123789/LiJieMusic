<?xml version="1.0" encoding="utf-8"?>
<!-- 🌟 1. 去掉 NestedScrollView，直接用 LinearLayout 当根布局 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MVFragment">

    <!-- 顶部的导航栏保持不变 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F5F5F8">

        <ImageView
            android:id="@+id/liebiao"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="14dp"
            android:src="@drawable/liebiao"
            app:tint="#333333" />

        <TextView
            android:id="@+id/tv_fake_search"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:layout_margin="16dp"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:paddingStart="12dp"
            android:text="欢迎来到网易MV"
            android:textStyle="bold"
            android:textColor="#999999"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/shiqu"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="14dp"
            android:src="@drawable/add"
            app:tint="#333333" />

    </LinearLayout>

    <!-- 🌟 2. 核心修改：让 RecyclerView 独占剩下的所有高度！ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="16dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false" />
    <!-- 注意上面两行，我把你刚才被底部播放条遮挡的解决方案也加进去了！ -->

    <!-- 加载文字 -->
    <TextView
        android:id="@+id/jiazai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="嗷嗷~ 正在拼命加载更多~"
        android:textStyle="bold"
        android:textColor="#999999"
        android:visibility="gone"
        android:gravity="center"
        android:padding="12dp"
        android:textSize="16sp"/>

</LinearLayout>