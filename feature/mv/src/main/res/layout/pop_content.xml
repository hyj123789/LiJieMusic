<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardCornerRadius="20dp"
        app:cardElevation="20dp"
        app:contentPadding="5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_area"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                android:text="地区" />

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                app:flexDirection="row"
                app:flexWrap="wrap"
                app:justifyContent="flex_start"
                app:layout_constraintTop_toBottomOf="@id/tv_area">

                <android.widget.Button
                    android:id="@+id/btn_area_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:text="全部"
                    style="@style/SelectorButtonStyle"
                    app:layout_constraintStart_toStartOf="parent" />

                <android.widget.Button
                    android:id="@+id/btn_area_cn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    style="@style/SelectorButtonStyle"
                    android:text="内地"
                    app:layout_constraintStart_toStartOf="parent" />

                <android.widget.Button
                    android:id="@+id/btn_area_ht"
                    android:layout_width="wrap_content"
                    style="@style/SelectorButtonStyle"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:text="港台"
                    app:layout_constraintStart_toStartOf="parent" />

                <android.widget.Button
                    android:id="@+id/btn_area_western"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/SelectorButtonStyle"
                    android:layout_margin="5dp"
                    android:text="欧美"
                    app:layout_constraintStart_toStartOf="parent" />

                <android.widget.Button
                    android:id="@+id/btn_area_japan"
                    android:layout_width="wrap_content"
                    style="@style/SelectorButtonStyle"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:text="日本"
                    app:layout_constraintStart_toStartOf="parent" />

                <android.widget.Button
                    android:id="@+id/btn_area_korea"
                    style="@style/SelectorButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:text="韩国"
                    app:layout_constraintStart_toStartOf="parent" />
            </com.google.android.flexbox.FlexboxLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardCornerRadius="20dp"
        app:cardElevation="20dp"
        app:contentPadding="5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="20dp"
                android:text="类型" />

            <com.google.android.flexbox.FlexboxLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                app:flexDirection="row"
                app:flexWrap="wrap"
                app:justifyContent="flex_start">

                <android.widget.Button
                    android:id="@+id/btn_type_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    style="@style/SelectorButtonStyle"
                    android:text="全部"
                    app:layout_constraintStart_toStartOf="parent" />

                <android.widget.Button
                    android:id="@+id/btn_type_official"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    style="@style/SelectorButtonStyle"
                    android:text="官方版"
                    app:layout_constraintStart_toStartOf="parent" />

                <android.widget.Button
                    android:id="@+id/btn_type_origin"
                    android:layout_width="wrap_content"
                    style="@style/SelectorButtonStyle"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:text="原生"
                    app:layout_constraintStart_toStartOf="parent" />

                <android.widget.Button
                    android:id="@+id/btn_type_live"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    style="@style/SelectorButtonStyle"
                    android:text="现场版"
                    app:layout_constraintStart_toStartOf="parent" />

                <android.widget.Button
                    android:id="@+id/btn_type_net_ease"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    style="@style/SelectorButtonStyle"
                    android:text="网易出品"
                    app:layout_constraintStart_toStartOf="parent" />
            </com.google.android.flexbox.FlexboxLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>