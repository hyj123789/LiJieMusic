<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_main"
    app:startDestination="@id/fragment_home">

    <fragment
        android:id="@+id/fragment_home"
        android:name="com.example.home.HomeFragment"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_fragment_home_to_searchFragment"
            app:destination="@id/searchFragment" />
        <action
            android:id="@+id/action_fragment_home_to_fragment_profile"
            app:destination="@id/fragment_profile" />

    </fragment>
    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.search.SearchFragment"
        android:label="SearchFragment" >

        <deepLink app:uri="musicapp://search_page" />

        <action
            android:id="@+id/action_searchFragment_to_fragment_home"
            app:destination="@id/fragment_home" />
        <action
            android:id="@+id/action_searchFragment_to_fragment_profile"
            app:destination="@id/fragment_profile" />
    </fragment>

    <fragment
        android:id="@+id/fragment_search"
        android:name="com.example.searchpage.SearchPageFragment"
        android:label="SearchPageFragment" />

    <fragment
        android:id="@+id/fragment_mv"
        android:name="com.example.mv.MVFragment"
        android:label="MVFragment" />

    <fragment
        android:id="@+id/playerFragment"
        android:name="com.example.player.PlayerFragment"
        tools:layout="@layout/fragment_player" />

    <fragment
        android:id="@+id/fragment_profile"
        android:name="com.example.profile.ProfileFragment"
        android:label="我的"
        tools:layout="@layout/fragment_profile" >
        <action
            android:id="@+id/action_fragment_profile_to_fragment_home"
            app:destination="@id/fragment_home" />
        <action
            android:id="@+id/action_fragment_profile_to_searchFragment"
            app:destination="@id/searchFragment" />
        <action
            android:id="@+id/action_fragment_profile_to_playlistFragment"
            app:destination="@id/playlistFragment" />
    </fragment>

    <fragment
        android:id="@+id/playlistFragment"
        android:name="com.example.playlist.PlaylistFragment"
        android:label="歌单详情"
        tools:layout="@layout/fragment_playlist">
        <deepLink app:uri="musicapp://playlist/{playlistId}" />
        <argument
            android:name="playlistId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/commentFragment"
        android:name="com.example.comment.CommentFragment"
        android:label="CommentFragment">

        <deepLink app:uri="lijiemusic://comment?songId={songId}&amp;songName={songName}&amp;coverUrl={coverUrl}" />

    </fragment>

</navigation>